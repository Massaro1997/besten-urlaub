generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Destination {
  id              String    @id @default(cuid())
  name            String
  country         String
  slug            String?   @unique
  category        String    @default("mare")
  imageUrl        String?
  description     String?
  popularity      Int?
  bestSeason      String?
  targetAudience  String?
  aiResearchNotes String?
  aiResearchDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  offers    Offer[]
  videos    Video[]
  creatives Creative[]
}

model Offer {
  id            String   @id @default(cuid())
  destinationId String
  title         String
  priceFrom     Float?
  affiliateLink String
  description   String?
  notes         String?
  usedInVideo   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  videoOffers VideoOffer[]
}

model Video {
  id            String    @id @default(cuid())
  destinationId String?
  title         String
  description   String?
  status        String    @default("pianificato")
  plannedDate   DateTime?
  publishedDate DateTime?
  hashtags      String?
  tiktokUrl     String?
  canvaDesignId String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  videoOffers VideoOffer[]
}

model VideoOffer {
  id      String @id @default(cuid())
  videoId String
  offerId String

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([videoId, offerId])
}

model Creative {
  id            String   @id @default(cuid())
  destinationId String?
  designType    String
  canvaDesignId String?
  editUrl       String?
  exportUrl     String?
  thumbnailUrl  String?
  queryUsed     String?
  createdAt     DateTime @default(now())

  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
}

model Setting {
  key   String @id
  value String
}
