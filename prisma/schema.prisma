generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Destination {
  id              String    @id @default(cuid())
  name            String
  country         String
  slug            String?   @unique
  category        String    @default("mare")
  imageUrl        String?
  description     String?
  popularity      Int?
  bestSeason      String?
  targetAudience  String?
  aiResearchNotes String?
  aiResearchDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  offers    Offer[]
  videos    Video[]
  creatives Creative[]
}

model Offer {
  id            String   @id @default(cuid())
  destinationId String
  title         String
  priceFrom     Float?
  affiliateLink String
  description   String?
  notes         String?
  usedInVideo   Boolean  @default(false)
  /// When true, the offer is shown in the "Top Deals" section on the homepage
  /// as a large card. Currently hand-curated (user tells us which 4 to feature).
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  videoOffers VideoOffer[]
}

model Video {
  id            String    @id @default(cuid())
  destinationId String?
  title         String
  description   String?
  status        String    @default("pianificato")
  plannedDate   DateTime?
  publishedDate DateTime?
  hashtags      String?
  tiktokUrl     String?
  canvaDesignId String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  videoOffers VideoOffer[]
}

model VideoOffer {
  id      String @id @default(cuid())
  videoId String
  offerId String

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([videoId, offerId])
}

model Creative {
  id            String   @id @default(cuid())
  destinationId String?
  designType    String
  canvaDesignId String?
  editUrl       String?
  exportUrl     String?
  thumbnailUrl  String?
  queryUsed     String?
  createdAt     DateTime @default(now())

  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
}

model Setting {
  key   String @id
  value String
}

/// One row per competitor TikTok account we track. Updated on every scrape
/// run — we upsert so that follower count / total videos stay current.
model CompetitorAccount {
  id             String   @id @default(cuid())
  username       String   @unique // TikTok @handle without the @
  nickname       String?
  signature      String?  // bio text
  bioLink        String?
  category       String?  // "affiliate" | "brand" | "partner" | "aggregator" | "creator"
  note           String?  // free-text note from config
  followerCount  Int?
  followingCount Int?
  heartCount     Int?     // total likes across all videos
  videoCount     Int?
  verified       Boolean? @default(false)
  lastScrapedAt  DateTime?
  firstSeenAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videos CompetitorVideo[]

  @@index([category])
}

/// One row per scraped TikTok video from a competitor. Uses TikTok's own
/// video id as primary key so re-scraping upserts cleanly without duplicates.
model CompetitorVideo {
  id                String   @id // TikTok video id (e.g. "7623808266220375328")
  username          String   // denormalized for fast filtering
  videoUrl          String
  description       String?  // caption text
  hashtags          String?  // comma-separated
  duration          Int?     // seconds
  createTime        DateTime // video post time on TikTok
  coverUrl          String?
  musicTitle        String?
  musicAuthor       String?
  playCount         Int      @default(0)
  diggCount         Int      @default(0) // likes
  commentCount      Int      @default(0)
  shareCount        Int      @default(0)
  collectCount      Int      @default(0) // saves
  // Derived metrics — recomputed on every scrape
  engagementRate    Float?   // (likes + comments + shares + saves) / plays
  saveRate          Float?   // saves / plays
  // Language detected by TikTok (ISO 639-1), used to filter DE-only videos
  textLanguage      String?
  // Which hashtag/profile this video was discovered through
  sourceHashtag     String?
  // Bookkeeping
  firstSeenAt       DateTime @default(now())
  lastScrapedAt     DateTime @default(now())

  account CompetitorAccount @relation(fields: [username], references: [username], onDelete: Cascade)

  @@index([username])
  @@index([createTime])
  @@index([playCount])
  @@index([engagementRate])
  @@index([textLanguage])
}

/// One row per item from our own TikTok account — used for benchmarking
/// vs competitors. Same shape as CompetitorVideo minus the account link.
model OwnTikTokVideo {
  id             String   @id // TikTok video id
  videoUrl       String
  description    String?
  hashtags       String?
  duration       Int?
  createTime     DateTime
  coverUrl       String?
  musicTitle     String?
  musicAuthor    String?
  playCount      Int      @default(0)
  diggCount      Int      @default(0)
  commentCount   Int      @default(0)
  shareCount     Int      @default(0)
  collectCount   Int      @default(0)
  engagementRate Float?
  saveRate       Float?
  firstSeenAt    DateTime @default(now())
  lastScrapedAt  DateTime @default(now())

  @@index([createTime])
  @@index([playCount])
}

/// One row per click-out from our site to Check24 (or any affiliate).
/// The `eventId` is the join key between:
///   - TikTok Pixel client/server events
///   - the subid we attach to the Check24 deep link
///   - the conversion postback when/if it arrives
model AffiliateClick {
  id         String   @id @default(cuid())
  eventId    String   @unique // ties pixel event <-> subid <-> postback
  offerId    String?
  ttclid     String?
  externalId String?
  ipHash     String?
  userAgent  String?
  referrer   String?
  landingUrl String?
  // Conversion fields — filled later by the postback handler
  converted  Boolean  @default(false)
  convValue  Float?
  convAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([offerId])
  @@index([createdAt])
}
